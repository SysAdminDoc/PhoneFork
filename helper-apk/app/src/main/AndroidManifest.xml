<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required to read what the host needs to migrate. Host installs this APK over ADB and uninstalls when done. -->
    <uses-permission android:name="android.permission.READ_SMS"/>
    <uses-permission android:name="android.permission.WRITE_SMS"
        tools:ignore="ProtectedPermissions"/>
    <uses-permission android:name="android.permission.READ_CALL_LOG"/>
    <uses-permission android:name="android.permission.WRITE_CALL_LOG"/>
    <uses-permission android:name="android.permission.READ_CONTACTS"/>
    <uses-permission android:name="android.permission.WRITE_CONTACTS"/>
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.SET_WALLPAPER"/>
    <uses-permission android:name="android.permission.READ_USER_DICTIONARY"
        tools:ignore="ProtectedPermissions"/>
    <uses-permission android:name="android.permission.WRITE_USER_DICTIONARY"
        tools:ignore="ProtectedPermissions"/>

    <!-- Android 13+ exposed app components must declare an exported attribute. The providers are exported false
         because they are reachable through `adb shell content query/insert` regardless: the shell UID has implicit
         provider access when the providing app is installed. No third-party app needs cross-process IPC against
         these authorities. -->
    <application
        android:label="PhoneForkHelper"
        android:allowBackup="false"
        android:enableOnBackInvokedCallback="true"
        android:hasFragileUserData="false"
        tools:targetApi="36">

        <!-- Providers: one per migration category. Body lives in providers/*.kt. -->
        <provider
            android:name=".providers.SmsProvider"
            android:authorities="com.sysadmindoc.phonefork.helper.sms"
            android:exported="false"/>
        <provider
            android:name=".providers.CallLogProvider"
            android:authorities="com.sysadmindoc.phonefork.helper.calllog"
            android:exported="false"/>
        <provider
            android:name=".providers.ContactsProvider"
            android:authorities="com.sysadmindoc.phonefork.helper.contacts"
            android:exported="false"/>
        <provider
            android:name=".providers.WifiProvider"
            android:authorities="com.sysadmindoc.phonefork.helper.wifi"
            android:exported="false"/>
        <provider
            android:name=".providers.WallpaperProvider"
            android:authorities="com.sysadmindoc.phonefork.helper.wallpaper"
            android:exported="false"/>
        <provider
            android:name=".providers.RingtoneProvider"
            android:authorities="com.sysadmindoc.phonefork.helper.ringtone"
            android:exported="false"/>
        <provider
            android:name=".providers.DictionaryProvider"
            android:authorities="com.sysadmindoc.phonefork.helper.dictionary"
            android:exported="false"/>

        <!-- Self-uninstall trigger (F019): host fires `am broadcast -a com.sysadmindoc.phonefork.helper.UNINSTALL`
             which schedules a self-`pm uninstall`. Used as a finalization step after migration completes. -->
        <receiver
            android:name=".receivers.UninstallReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.sysadmindoc.phonefork.helper.UNINSTALL"/>
            </intent-filter>
        </receiver>
    </application>
</manifest>
