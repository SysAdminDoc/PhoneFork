<UserControl x:Class="PhoneFork.App.Views.OperationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PhoneFork.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:OperationsViewModel}">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="Migration operations" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource ForegroundMutedBrush}"
                               TextWrapping="Wrap" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Refresh" Command="{Binding RefreshOverviewCommand}" Margin="0,0,8,0"/>
                    <Button Content="Pre-flight" Command="{Binding RunPreflightCommand}" Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
                    <Button Content="Verify media" Command="{Binding VerifyMediaIntegrityCommand}" Margin="0,0,8,0"/>
                    <Button Content="Toggle burst" Command="{Binding ToggleBurstCommand}"/>
                </StackPanel>

                <UniformGrid Grid.Row="1" Grid.ColumnSpan="2" Columns="2" Margin="0,12,0,0">
                    <TextBlock Text="{Binding SourceLine}" Foreground="{StaticResource ForegroundBrush}" TextWrapping="Wrap" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding DestinationLine}" Foreground="{StaticResource ForegroundBrush}" TextWrapping="Wrap"/>
                </UniformGrid>
            </Grid>
        </Border>

        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="0.85*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Helper and privileged-read posture" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="Install, probe, or remove the helper APK on either assigned phone. Shizuku checks are read-only."
                               Foreground="{StaticResource ForegroundMutedBrush}" TextWrapping="Wrap" Margin="0,3,0,12"/>
                    <TextBlock Text="Helper APK path" Foreground="{StaticResource ForegroundMutedBrush}"/>
                    <TextBox Text="{Binding HelperApkPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,18,0">
                            <TextBlock Text="Source" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Install" Command="{Binding InstallHelperSourceCommand}" Margin="0,0,6,0"/>
                                <Button Content="Probe" Command="{Binding ProbeHelperSourceCommand}" Margin="0,0,6,0"/>
                                <Button Content="Uninstall" Command="{Binding UninstallHelperSourceCommand}" Margin="0,0,6,0"/>
                                <Button Content="Shizuku" Command="{Binding CheckShizukuSourceCommand}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Destination" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Install" Command="{Binding InstallHelperDestinationCommand}" Margin="0,0,6,0"/>
                                <Button Content="Probe" Command="{Binding ProbeHelperDestinationCommand}" Margin="0,0,6,0"/>
                                <Button Content="Uninstall" Command="{Binding UninstallHelperDestinationCommand}" Margin="0,0,6,0"/>
                                <Button Content="Shizuku" Command="{Binding CheckShizukuDestinationCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Host handoffs and local trust" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SmartSwitchLine}" Foreground="{StaticResource ForegroundMutedBrush}"
                               TextWrapping="Wrap" Margin="0,3,0,10"/>
                    <TextBlock Text="{Binding TrustedLine}" Foreground="{StaticResource ForegroundMutedBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding BurstLine}" Foreground="{StaticResource ForegroundMutedBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Detect Smart Switch" Command="{Binding DetectSmartSwitchCommand}" Margin="0,0,8,0"/>
                        <Button Content="Refresh trust" Command="{Binding RefreshOverviewCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Backup interop inspection" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="Paste a backup file or directory to classify AppManager, legacy Android .ab, or Open Android Backup material."
                               Foreground="{StaticResource ForegroundMutedBrush}" TextWrapping="Wrap" Margin="0,3,0,10"/>
                    <TextBox Text="{Binding BackupPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <Button Content="Inspect backup" Command="{Binding InspectBackupCommand}" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Pre-flight and integrity summary" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding PreflightLine}" Foreground="{StaticResource ForegroundMutedBrush}"
                               TextWrapping="Wrap" Margin="0,3,0,10"/>
                    <TextBlock Text="{Binding MessagesLine}" Foreground="{StaticResource ForegroundMutedBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding MediaIntegrityLine}" Foreground="{StaticResource ForegroundMutedBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*"/>
                <ColumnDefinition Width="0.75*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="160"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" Padding="0" Margin="0,0,12,12">
                <DataGrid ItemsSource="{Binding Rows}" IsReadOnly="True" CanUserAddRows="False"
                          RowHeight="30" Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="70"/>
                        <DataGridTextColumn Header="Area" Binding="{Binding Area}" Width="130"/>
                        <DataGridTextColumn Header="State" Binding="{Binding State}" Width="100"/>
                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="80"/>
                        <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,12">
                <DataGrid ItemsSource="{Binding PreflightFindings}" IsReadOnly="True" CanUserAddRows="False"
                          RowHeight="34" Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="75"/>
                        <DataGridTextColumn Header="Finding" Binding="{Binding Title}" Width="1.2*"/>
                        <DataGridTextColumn Header="Package" Binding="{Binding PackageId}" Width="1.1*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding TrustedPairs}" IsReadOnly="True" CanUserAddRows="False"
                          RowHeight="30" Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="1.4*"/>
                        <DataGridTextColumn Header="Hash" Binding="{Binding SerialHash}" Width="1.2*"/>
                        <DataGridTextColumn Header="Transport" Binding="{Binding Transport}" Width="90"/>
                        <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}" Width="150"/>
                        <DataGridTextColumn Header="Endpoint" Binding="{Binding LastEndpoint}" Width="1.2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
