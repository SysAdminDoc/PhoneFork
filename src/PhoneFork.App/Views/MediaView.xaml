<UserControl x:Class="PhoneFork.App.Views.MediaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PhoneFork.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MediaViewModel}">

    <DockPanel>
        <!-- Action row -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,12">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Scan"            Command="{Binding ScanCommand}"    Margin="0,0,8,0"/>
                    <Button Content="Apply Sync"      Command="{Binding ApplyCommand}"   Style="{StaticResource AccentButton}" Margin="0,0,16,0"/>
                    <Button Content="Select All"      Command="{Binding SelectAllCommand}"  Margin="0,0,4,0"/>
                    <Button Content="Select None"     Command="{Binding SelectNoneCommand}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <CheckBox Content="Dry-run"               IsChecked="{Binding DryRun}"           VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <CheckBox Content="Update-only"           IsChecked="{Binding UpdateOnly}"       VerticalAlignment="Center" Margin="0,0,16,0"
                              ToolTip="On conflict, only overwrite if source mtime > destination mtime"/>
                    <CheckBox Content="Preserve conflicts"    IsChecked="{Binding PreserveConflicts}" VerticalAlignment="Center" Margin="0,0,16,0"
                              ToolTip="Rename destination conflicts to *.sync-conflict-* before overwriting"/>
                    <CheckBox Content="Delete dest-only"      IsChecked="{Binding Delete}"           VerticalAlignment="Center"
                              ToolTip="Delete files that exist only on destination (mirror source exactly)"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status + summary -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource ForegroundBrush}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding CurrentFile}" Foreground="{StaticResource ForegroundMutedBrush}"
                               FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                               TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock HorizontalAlignment="Right">
                        <Run Text="Files: " Foreground="{StaticResource ForegroundMutedBrush}"/>
                        <Run Text="{Binding TotalFiles}" FontWeight="SemiBold"/>
                        <Run Text="   " />
                        <Run Text="MiB: " Foreground="{StaticResource ForegroundMutedBrush}"/>
                        <Run Text="{Binding TotalMib, StringFormat=F1}" FontWeight="SemiBold"/>
                        <Run Text="   " />
                        <Run Text="Conflicts: " Foreground="{StaticResource ForegroundMutedBrush}"/>
                        <Run Text="{Binding TotalConflicts}" FontWeight="SemiBold" Foreground="{StaticResource MochaPeachBrush}"/>
                    </TextBlock>
                    <ProgressBar Width="280" Height="6" Margin="0,8,0,0"
                                 Value="{Binding ProgressPercent}" Minimum="0" Maximum="100"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="{StaticResource MochaSurface1Brush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Category table -->
        <Border Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Rows}"
                      RowHeight="32"
                      Background="Transparent"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header=" " Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                    <DataGridTextColumn Header="Category"      Binding="{Binding Label}"      Width="1.4*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Remote root"   Binding="{Binding RemoteRoot}" Width="1.6*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Src files"     Binding="{Binding SrcFiles}"   Width="80"   IsReadOnly="True"/>
                    <DataGridTextColumn Header="Src MiB"       Binding="{Binding SrcMib, StringFormat=F1}" Width="80" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Dst files"     Binding="{Binding DstFiles}"   Width="80"   IsReadOnly="True"/>
                    <DataGridTextColumn Header="New"           Binding="{Binding PlanNew}"        Width="60" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Conflict"      Binding="{Binding PlanConflicts}"  Width="70" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Same"          Binding="{Binding PlanIdentical}"  Width="60" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Dst-only"      Binding="{Binding PlanOnlyOnDst}"  Width="80" IsReadOnly="True"/>
                    <DataGridTextColumn Header="MiB to xfer"   Binding="{Binding PlanMib, StringFormat=F1}" Width="100" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>
