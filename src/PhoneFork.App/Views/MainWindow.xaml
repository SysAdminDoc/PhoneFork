<Window x:Class="PhoneFork.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PhoneFork.App.Views"
        xmlns:conv="clr-namespace:PhoneFork.App.Converters"
        xmlns:vm="clr-namespace:PhoneFork.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="PhoneFork  &#x00B7;  v0.6.6"
        MinWidth="1100" MinHeight="700"
        Width="1280" Height="820"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- App title row -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <TextBlock Text="PhoneFork" FontSize="26" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text=" v0.6.6" FontSize="20" Margin="6,4,0,0"
                           Foreground="{StaticResource ForegroundMutedBrush}"/>
            </StackPanel>
            <TextBlock Text="Dual-Samsung migration &#x00B7; local-only &#x00B7; no root &#x00B7; no cloud"
                       FontSize="13" Margin="16,8,0,0"
                       Foreground="{StaticResource ForegroundMutedBrush}"
                       DockPanel.Dock="Left"/>
        </DockPanel>

        <!-- Device bar -->
        <views:DeviceBar Grid.Row="1" DataContext="{Binding DeviceBar}"/>

        <!-- Tabs -->
        <TabControl Grid.Row="2" Padding="0">
            <TabItem Header="Apps">
                <views:AppsView DataContext="{Binding Apps}" Margin="0,12,0,0"/>
            </TabItem>
            <TabItem Header="Media">
                <views:MediaView DataContext="{Binding Media}" Margin="0,12,0,0"/>
            </TabItem>
            <TabItem Header="Settings">
                <views:SettingsView DataContext="{Binding Settings}" Margin="0,12,0,0"/>
            </TabItem>
            <TabItem Header="Debloat">
                <views:DebloatView DataContext="{Binding Debloat}" Margin="0,12,0,0"/>
            </TabItem>
            <TabItem Header="Wi-Fi">
                <views:WifiView DataContext="{Binding Wifi}" Margin="0,12,0,0"/>
            </TabItem>
            <TabItem Header="Roles">
                <views:RolesView DataContext="{Binding Roles}" Margin="0,12,0,0"/>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock Foreground="{StaticResource ForegroundMutedBrush}" FontSize="11"
                       DockPanel.Dock="Left">
                <Run Text="Audit log:"/>
                <Run Text="%LOCALAPPDATA%\PhoneFork\logs\"/>
            </TextBlock>
            <TextBlock Foreground="{StaticResource ForegroundMutedBrush}" FontSize="11"
                       HorizontalAlignment="Right" DockPanel.Dock="Right">
                MIT &#x00B7; https://github.com/SysAdminDoc/PhoneFork
            </TextBlock>
        </DockPanel>
    </Grid>
</Window>
