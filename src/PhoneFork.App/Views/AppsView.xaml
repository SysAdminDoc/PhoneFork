<UserControl x:Class="PhoneFork.App.Views.AppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PhoneFork.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:AppsViewModel}">

    <DockPanel Margin="0,0,0,0">
        <!-- Action row -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,12">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="App migration" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="Pulls every split APK from the source and installs it on the destination with Play Store attribution."
                               Foreground="{StaticResource ForegroundMutedBrush}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Scan Source"      Command="{Binding ScanCommand}"     Margin="0,0,8,0"
                            AutomationProperties.Name="Scan source phone user apps"/>
                    <Button Content="Migrate Selected" Command="{Binding MigrateCommand}"  Style="{StaticResource AccentButton}" Margin="0,0,16,0"
                            AutomationProperties.Name="Migrate selected applications"/>
                    <Button Content="Select All"       Command="{Binding SelectAllCommand}" Margin="0,0,4,0"/>
                    <Button Content="Select None"      Command="{Binding SelectNoneCommand}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" Margin="16,0,0,0">
                    <CheckBox Content="Dry-run" IsChecked="{Binding DryRun}" VerticalAlignment="Center" Margin="0,0,14,0"
                              ToolTip="Pull APKs only. Nothing installs on the destination."/>
                    <CheckBox Content="Reinstall" IsChecked="{Binding Reinstall}" VerticalAlignment="Center"
                              ToolTip="Allow installing over packages that already exist on the destination."/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status row -->
        <Border DockPanel.Dock="Top" Style="{StaticResource SubtleCard}" Margin="0,0,0,12">
            <DockPanel LastChildFill="False">
                <TextBlock Text="{Binding Status}" Foreground="{StaticResource ForegroundBrush}" DockPanel.Dock="Left"/>
                <TextBlock HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Run Text="Selected: " Foreground="{StaticResource ForegroundMutedBrush}"/>
                    <Run Text="{Binding SelectedCount}" FontWeight="SemiBold"/>
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- Table -->
        <Border Style="{StaticResource Card}" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Rows}"
                          IsReadOnly="False"
                          CanUserResizeRows="False"
                          RowHeight="32"
                          Background="Transparent"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header=" " Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                        <DataGridTextColumn Header="Package" Binding="{Binding PackageName}" Width="2*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Label"   Binding="{Binding Label}"       Width="1.6*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Version" Binding="{Binding Version}"     Width="120"  IsReadOnly="True"/>
                        <DataGridTextColumn Header="Splits"  Binding="{Binding SplitCount}"  Width="60"   IsReadOnly="True"/>
                        <DataGridTextColumn Header="Size"    Binding="{Binding SizeText}"    Width="90"   IsReadOnly="True"/>
                        <DataGridTextColumn Header="Status"  Binding="{Binding Status}"      Width="1.4*" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
                <Border Style="{StaticResource SubtleCard}" Margin="16"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding HasRows, Converter={StaticResource InverseBoolToVis}}">
                    <StackPanel Width="420">
                        <TextBlock Text="Scan source apps to start" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="PhoneFork previews every app and split before migration. Nothing installs until you choose rows and run the migration."
                                   Foreground="{StaticResource ForegroundMutedBrush}"
                                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </DockPanel>
</UserControl>
