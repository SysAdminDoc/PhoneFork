<UserControl x:Class="PhoneFork.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PhoneFork.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}">

    <DockPanel>
        <!-- Action row -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,12">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Scan"        Command="{Binding ScanCommand}"   Margin="0,0,8,0"/>
                    <Button Content="Apply"       Command="{Binding ApplyCommand}"  Style="{StaticResource AccentButton}" Margin="0,0,16,0"/>
                    <Button Content="Select All applicable" Command="{Binding SelectAllCommand}"  Margin="0,0,4,0"/>
                    <Button Content="Select None" Command="{Binding SelectNoneCommand}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{StaticResource ForegroundMutedBrush}"/>
                    <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" MinWidth="200" Margin="0,0,16,0"/>
                    <CheckBox Content="Show only applicable" IsChecked="{Binding ShowOnlyApplicable}" VerticalAlignment="Center" Margin="0,0,16,0"
                              ToolTip="Hide rows that are already aligned (Same) or only exist on the destination."/>
                    <CheckBox Content="Dry-run"  IsChecked="{Binding DryRun}" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status row -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock Text="{Binding Status}" Foreground="{StaticResource ForegroundBrush}" DockPanel.Dock="Left"/>
                <TextBlock HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Run Text="Different: " Foreground="{StaticResource ForegroundMutedBrush}"/>
                    <Run Text="{Binding TotalDifferent}" FontWeight="SemiBold" Foreground="{StaticResource MochaPeachBrush}"/>
                    <Run Text="   " />
                    <Run Text="Only on src: " Foreground="{StaticResource ForegroundMutedBrush}"/>
                    <Run Text="{Binding TotalOnlyOnSource}" FontWeight="SemiBold" Foreground="{StaticResource MochaBlueBrush}"/>
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- Diff table -->
        <Border Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding FilteredRows}"
                      RowHeight="28"
                      Background="Transparent"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header=" "    Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                    <DataGridTextColumn Header="Ns"      Binding="{Binding NamespaceText}" Width="70"  IsReadOnly="True"/>
                    <DataGridTextColumn Header="Key"     Binding="{Binding Key}"           Width="2.5*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Outcome" Binding="{Binding OutcomeText}"   Width="90"  IsReadOnly="True"/>
                    <DataGridTextColumn Header="Source value" Binding="{Binding SourceValue}" Width="2*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Dest value"   Binding="{Binding DestValue}"   Width="2*" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>
