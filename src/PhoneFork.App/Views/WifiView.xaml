<UserControl x:Class="PhoneFork.App.Views.WifiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PhoneFork.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:WifiViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="420"/>
        </Grid.ColumnDefinitions>

        <!-- Status row -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource SubtleCard}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Wi-Fi and region pre-flight" FontSize="15" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Status}" Foreground="{StaticResource ForegroundMutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- CSC diff card -->
        <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource Card}" Margin="0,0,0,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Text="Region compatibility" FontWeight="SemiBold"/>
                    <TextBlock Text="Checks CSC, country, locale, timezone, and carrier ISO before Wi-Fi handoff."
                               Foreground="{StaticResource ForegroundMutedBrush}" TextWrapping="Wrap" Margin="0,3,0,8"/>
                    <Button Content="Capture region info from both phones" Command="{Binding ScanCscCommand}" HorizontalAlignment="Left"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Source" Foreground="{StaticResource ForegroundMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CscSource}" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Dest"   Foreground="{StaticResource ForegroundMutedBrush}" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CscDest}"   FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding CscWarning}" Foreground="{StaticResource MochaPeachBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                </Grid>
            </DockPanel>
        </Border>

        <!-- LEFT: SSID list from source -->
        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="SSIDs on source device" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="PSKs are typed by the user until the helper APK lands."
                                   Foreground="{StaticResource ForegroundMutedBrush}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Content="Scan source" Command="{Binding ScanSourceCommand}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                </DockPanel>
                <Grid>
                    <DataGrid ItemsSource="{Binding Ssids}" RowHeight="28" Background="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SSID" Binding="{Binding Ssid}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Auth" Binding="{Binding Auth}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Hidden" Binding="{Binding Hidden}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Enter PSK to build QR" Binding="{Binding TypedPsk, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            <DataGridTemplateColumn Header=" " Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Use" Command="{Binding DataContext.UseRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Style="{StaticResource SubtleCard}" Margin="16"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasSsids, Converter={StaticResource InverseBoolToVis}}">
                        <StackPanel Width="360">
                            <TextBlock Text="Scan source Wi-Fi networks" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Detected SSIDs can prefill the QR composer; passwords are not read from Android without the v0.7 helper path."
                                       Foreground="{StaticResource ForegroundMutedBrush}"
                                       TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>

        <!-- RIGHT: QR composer -->
        <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Manual join-QR composer" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock Text="Builds a standard Android camera-scannable network QR."
                           Foreground="{StaticResource ForegroundMutedBrush}" TextWrapping="Wrap" Margin="0,3,0,10"/>
                <TextBlock Text="SSID" Foreground="{StaticResource ForegroundMutedBrush}" FontSize="11"/>
                <TextBox Text="{Binding QrSsid, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>
                <TextBlock Text="Pre-shared key" Foreground="{StaticResource ForegroundMutedBrush}" FontSize="11"/>
                <TextBox Text="{Binding QrPsk, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="Auth" Foreground="{StaticResource ForegroundMutedBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left"/>
                    <CheckBox Content="Hidden" IsChecked="{Binding QrHidden}" VerticalAlignment="Center" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                    <ComboBox ItemsSource="{Binding AuthChoices}" SelectedItem="{Binding QrAuth}"/>
                </DockPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="Build QR" Command="{Binding BuildQrCommand}" Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
                    <Button Content="Save PNG" Command="{Binding SaveQrCommand}"/>
                </StackPanel>
                <Border Background="{StaticResource MochaSurface0Brush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        HorizontalAlignment="Center">
                    <Grid Width="320" Height="320">
                        <Image Source="{Binding QrImage}" Stretch="Uniform"
                               Visibility="{Binding QrImage, Converter={StaticResource NullToVis}}"/>
                        <TextBlock Text="QR preview appears here"
                                   Foreground="{StaticResource ForegroundMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding QrImage, Converter={StaticResource InverseNullToVis}}"/>
                    </Grid>
                </Border>
                <TextBlock Text="{Binding QrPayload}" Foreground="{StaticResource ForegroundMutedBrush}"
                           FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                           TextWrapping="Wrap" Margin="0,8,0,0"/>
                <TextBlock Text="{Binding SavedQrPath}" Foreground="{StaticResource MochaGreenBrush}"
                           FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
